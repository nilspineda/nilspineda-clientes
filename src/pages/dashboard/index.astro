---
import Layout from '../../layouts/Layout.astro';
import { getSupabase } from '../../lib/supabase';
import ServiceCard from '../../components/ServiceCard.astro';
import PaymentCard from '../../components/PaymentCard.astro';

const supabase = getSupabase(Astro.cookies);
const { data: { user }, error } = await supabase.auth.getUser();

if (error || !user) {
  return Astro.redirect("/login");
}

const { data: profile } = await supabase
  .from('profiles')
  .select('*')
  .eq('id', user.id)
  .single();

// Redirect to admin panel if user is admin
if (profile?.role === 'admin') {
  return Astro.redirect('/admin');
}

// Fetch user services
const { data: userServices } = await supabase
  .from('user_services')
  .select(`
    *,
    service:services(*)
  `)
  .eq('user_id', user.id)
  .order('created_at', { ascending: false });

// Fetch user payments
const { data: payments } = await supabase
  .from('payments')
  .select(`
    *,
    service:services(*)
  `)
  .eq('user_id', user.id)
  .order('payment_date', { ascending: false });

const supportNumber = "1234567890"; // Example number
---

<Layout title="Dashboard | SaaS">
  <div class="min-h-screen bg-slate-50">
    <nav class="bg-white border-b border-slate-200 sticky top-0 z-10 shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex items-center">
            <div class="flex-shrink-0 flex items-center gap-2">
              <div class="w-8 h-8 rounded-lg bg-blue-600 flex items-center justify-center">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
              </div>
              <span class="font-bold text-xl text-slate-900 tracking-tight">Panel Cliente</span>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="hidden sm:flex items-center gap-2 bg-slate-100 px-3 py-1.5 rounded-full">
              <div class="w-6 h-6 bg-blue-100 rounded-full flex items-center justify-center text-blue-600 text-xs font-bold">
                {(profile?.name || user.email).charAt(0).toUpperCase()}
              </div>
              <span class="text-sm font-medium text-slate-700">{profile?.name || user.email}</span>
            </div>
            <a href="/api/auth/signout" class="text-sm font-medium text-slate-500 hover:text-red-600 transition-colors">Cerrar Sesión</a>
          </div>
        </div>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <div class="lg:col-span-2 space-y-8">
          <section>
            <div class="mb-6 flex justify-between items-end">
              <div>
                <h2 class="text-2xl font-bold text-slate-900">Mis Servicios</h2>
                <p class="text-slate-500 mt-1 text-sm">Gestiona tus suscripciones actuales y renovaciones</p>
              </div>
            </div>

            {userServices && userServices.length > 0 ? (
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {userServices.map(us => (
                  <ServiceCard userService={us} whatsappNumber={supportNumber} />
                ))}
              </div>
            ) : (
              <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-12 text-center">
                <div class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-4">
                  <svg class="w-8 h-8 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
                </div>
                <h3 class="text-lg font-medium text-slate-900">No tienes servicios activos</h3>
                <p class="text-slate-500 mt-2 text-sm">Contacta a soporte para adquirir un nuevo servicio.</p>
                <div class="mt-6">
                  <a href={`https://wa.me/${supportNumber}?text=Hola%20quiero%20adquirir%20un%20servicio`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 bg-blue-600 text-white text-sm font-medium rounded-xl hover:bg-blue-700 transition-colors shadow-sm">
                    Contactar Soporte
                  </a>
                </div>
              </div>
            )}
          </section>
        </div>

        <div class="lg:col-span-1 space-y-8">
          <section>
            <div class="mb-6">
              <h2 class="text-xl font-bold text-slate-900">Historial de Pagos</h2>
              <p class="text-slate-500 mt-1 text-sm">Tus últimos pagos registrados</p>
            </div>
            
            <div class="bg-slate-50 rounded-2xl p-1.5 border border-slate-200">
              {payments && payments.length > 0 ? (
                <div class="space-y-1.5">
                  {payments.map(payment => (
                    <PaymentCard payment={payment} />
                  ))}
                </div>
              ) : (
                <div class="p-8 text-center bg-white rounded-xl m-1 border border-slate-100">
                  <svg class="w-10 h-10 text-slate-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                  <p class="text-slate-500 text-sm">Aún no tienes pagos registrados.</p>
                </div>
              )}
            </div>
          </section>
        </div>

      </div>
    </main>
  </div>
</Layout>
