---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getSupabase } from '../../lib/supabase';

const supabase = getSupabase(Astro.cookies);
const { data: { user }, error } = await supabase.auth.getUser();

if (error || !user) {
  return Astro.redirect("/login");
}

const { data: profile } = await supabase
  .from('profiles')
  .select('*')
  .eq('id', user.id)
  .single();

if (profile?.role !== 'admin') {
  return Astro.redirect('/dashboard');
}

// Stats
const { count: usersCount } = await supabase.from('profiles').select('*', { count: 'exact', head: true });
const { count: servicesCount } = await supabase.from('services').select('*', { count: 'exact', head: true });
const { count: activeServicesCount } = await supabase.from('user_services').select('*', { count: 'exact', head: true }).eq('status', 'active');
const { count: paymentsCount } = await supabase.from('payments').select('*', { count: 'exact', head: true });
---

<AdminLayout title="Panel Admin | Resumen" currentPath="/admin">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-slate-900 tracking-tight">Resumen General</h1>
    <p class="text-slate-500 mt-2">Bienvenido al panel de administración del SaaS.</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
    <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
      <div class="flex items-center gap-4 mb-2">
        <div class="w-12 h-12 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
        </div>
        <div>
          <p class="text-sm font-medium text-slate-500">Usuarios Totales</p>
          <p class="text-3xl font-bold text-slate-900 tracking-tight">{usersCount || 0}</p>
        </div>
      </div>
    </div>
    
    <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
      <div class="flex items-center gap-4 mb-2">
        <div class="w-12 h-12 rounded-xl bg-purple-50 text-purple-600 flex items-center justify-center">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
        </div>
        <div>
          <p class="text-sm font-medium text-slate-500">Servicios Base</p>
          <p class="text-3xl font-bold text-slate-900 tracking-tight">{servicesCount || 0}</p>
        </div>
      </div>
    </div>

    <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
      <div class="flex items-center gap-4 mb-2">
        <div class="w-12 h-12 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        </div>
        <div>
          <p class="text-sm font-medium text-slate-500">Servicios Activos</p>
          <p class="text-3xl font-bold text-slate-900 tracking-tight">{activeServicesCount || 0}</p>
        </div>
      </div>
    </div>

    <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
      <div class="flex items-center gap-4 mb-2">
        <div class="w-12 h-12 rounded-xl bg-amber-50 text-amber-600 flex items-center justify-center">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        </div>
        <div>
          <p class="text-sm font-medium text-slate-500">Pagos Registrados</p>
          <p class="text-3xl font-bold text-slate-900 tracking-tight">{paymentsCount || 0}</p>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>
