---
import StatusBadge from './StatusBadge.astro';
import WhatsAppButton from './WhatsAppButton.astro';

const { userService, whatsappNumber } = Astro.props;
const { service, status, expires_at } = userService;

// Calculate remaining days
let daysRemaining = null;
if (expires_at) {
  const expiresDate = new Date(expires_at);
  const today = new Date();
  const diffTime = Math.max(0, expiresDate.getTime() - today.getTime());
  daysRemaining = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
}
---

<div class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
  <div class="flex justify-between items-start mb-4">
    <div>
      <h3 class="text-lg font-bold text-slate-900">{service?.name || 'Servicio Eliminado'}</h3>
      <p class="text-sm text-slate-500 mt-1">{service?.description || ''}</p>
    </div>
    <StatusBadge status={status} />
  </div>
  
  <div class="grid grid-cols-2 gap-4 mb-6">
    <div class="bg-slate-50 rounded-lg p-3 border border-slate-100">
      <p class="text-xs text-slate-500 font-medium uppercase tracking-wide">Vencimiento</p>
      <p class="text-sm font-semibold text-slate-900 mt-1">
        {expires_at ? new Date(expires_at).toLocaleDateString() : 'No definido'}
      </p>
    </div>
    <div class="bg-slate-50 rounded-lg p-3 border border-slate-100">
      <p class="text-xs text-slate-500 font-medium uppercase tracking-wide">Días Restantes</p>
      <p class="text-sm font-semibold text-slate-900 mt-1">
        {daysRemaining !== null ? daysRemaining : '-'}
      </p>
    </div>
  </div>

  <div class="flex items-center gap-3">
    {service && <WhatsAppButton number={whatsappNumber} serviceName={service.name} />}
  </div>
</div>
