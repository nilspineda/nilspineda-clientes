---
import StatusBadge from './StatusBadge.astro';

const { payment } = Astro.props;
const { amount, payment_date, status, invoice_url, service } = payment;
---

<div class="flex items-center justify-between p-4 bg-white border border-slate-200 rounded-xl hover:shadow-sm transition-shadow">
  <div class="flex items-center gap-4">
    <div class="w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center text-blue-600">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
    </div>
    <div>
      <h4 class="text-sm font-bold text-slate-900">{service?.name || 'Servicio'}</h4>
      <p class="text-xs text-slate-500">{new Date(payment_date).toLocaleDateString()}</p>
    </div>
  </div>
  
  <div class="flex items-center gap-6">
    <div class="text-right">
      <p class="text-sm font-bold text-slate-900">${amount}</p>
      <div class="mt-1">
        <StatusBadge status={status} />
      </div>
    </div>
    
    {invoice_url && (
      <a href={invoice_url} target="_blank" rel="noopener noreferrer" 
        class="p-2 text-slate-400 hover:text-blue-600 bg-slate-50 hover:bg-blue-50 rounded-lg transition-colors border border-slate-200 hover:border-blue-200"
        title="Descargar Factura">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
      </a>
    )}
  </div>
</div>
